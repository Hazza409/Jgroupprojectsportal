# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Postgres. Matches docker-compose.yml for local dev.
DATABASE_URL="postgresql://jgroup:jgroup@localhost:5432/jgroup?schema=public"

# NextAuth. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# ── File storage ──────────────────────────────────────────────
# STORAGE_DRIVER: "local" (dev, writes to ./storage-data) or "s3"
STORAGE_DRIVER="local"
LOCAL_STORAGE_DIR="./storage-data"

# S3-compatible (AWS S3, Cloudflare R2, MinIO, Supabase Storage…). Only needed when STORAGE_DRIVER=s3.
S3_ENDPOINT=""              # e.g. https://<account>.r2.cloudflarestorage.com  (blank = AWS)
S3_REGION="us-east-1"
S3_BUCKET="jgroup-dashboard"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"  # true for MinIO/R2

# ── Xero (one-directional: Xero → dashboard) ──────────────────
# Create an app at https://developer.xero.com. Sync + invoice-push are TODO interfaces.
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"
