# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Postgres. Matches docker-compose.yml for local dev.
DATABASE_URL="postgresql://jgroup:jgroup@localhost:5432/jgroup?schema=public"

# NextAuth. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# ── File storage ──────────────────────────────────────────────
# STORAGE_DRIVER: "local" (dev, writes to ./storage-data) or "s3"
STORAGE_DRIVER="local"
LOCAL_STORAGE_DIR="./storage-data"

# S3-compatible (AWS S3, Cloudflare R2, MinIO, Supabase Storage…). Only needed when STORAGE_DRIVER=s3.
S3_ENDPOINT=""              # e.g. https://<account>.r2.cloudflarestorage.com  (blank = AWS)
S3_REGION="us-east-1"
S3_BUCKET="jgroup-dashboard"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"  # true for MinIO/R2

# ── Xero (one-directional: Xero → dashboard) ──────────────────
# Create an app at https://developer.xero.com and add the redirect URI below to it.
# OAuth + read-only actuals sync are implemented. Invoice-push stays a guarded TODO.
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"

# Key used to encrypt stored Xero tokens at rest (AES-256-GCM). Generate with
# openssl rand -base64 32. Falls back to NEXTAUTH_SECRET if unset.
XERO_TOKEN_KEY=""

# ── Email notifications ───────────────────────────────────────
# Clients + PMs are emailed on claims/variations/RFIs/updates/meetings.
# EMAIL_DRIVER: "console" (dev — prints to server log), "smtp"/"gmail"
# (send through an existing mailbox, e.g. Google Workspace with an App
# Password — no DNS setup), or "resend" (API sending, needs domain DNS).
EMAIL_DRIVER="console"
# smtp/gmail driver: the mailbox that sends. SMTP_PASS for Gmail is a 16-char
# App Password (myaccount.google.com/apppasswords — needs 2-Step Verification).
SMTP_USER=""
SMTP_PASS=""
# SMTP_HOST defaults to smtp.gmail.com, SMTP_PORT to 465 — only set for non-Gmail.
# resend driver: create a key at https://resend.com.
RESEND_API_KEY=""
# Optional. smtp: defaults to "J Group Projects <SMTP_USER>" (Gmail can only
# send as the authenticated mailbox / its aliases).
EMAIL_FROM=""
