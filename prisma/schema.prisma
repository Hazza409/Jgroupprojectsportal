// J Group Projects — client + builder dashboard.
// Currency rule: every monetary value is an Int of CENTS. Never Float for money.
// Project scoping: every project-bound row carries projectId; access is enforced
// at the query layer via src/lib/scope.ts (assertProjectAccess), not just the UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  BUILDER // J Group staff — sees ALL projects
  CLIENT // sees only projects they're a member of
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum VariationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum DesignDocKind {
  ARCHITECTURAL
  INTERIOR
  OTHER
}

// Project lifecycle. Modules surface by phase; all data stays accessible.
enum ProjectPhase {
  BUILD
  HANDOVER
  MAINTENANCE
}

// What the CLIENT sees. Builders always see every module; this only changes the
// client's view. Decoupled from `phase` so the builder can flip the client to the
// handover view without advancing the internal lifecycle.
enum ProjectClientView {
  CONSTRUCTION // client sees the build modules (estimate, schedule, claims, variations, RFIs…)
  HANDOVER     // client sees the combined Handover & Maintenance area only
}

// One calendar, typed events (site meetings, maintenance, service bookings).
enum CalendarEventKind {
  SITE_MEETING
  MAINTENANCE
  BOOKING
}

// Handover document repositories.
enum HandoverDocKind {
  REGISTER // master document register
  OM_MANUAL // operation & maintenance manuals
  WARRANTY // warranty docs (structured records live in Warranty)
  JGROUP // J Group company-issued handover docs
}

enum ServiceBookingStatus {
  REQUESTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum QuoteRequestStatus {
  OPEN
  QUOTED
  ACCEPTED
  DECLINED
}

// RFI = builder asks the client a design question; client answers.
enum RfiStatus {
  OPEN // awaiting client answer
  ANSWERED // client answered
  CLOSED // builder closed it out
}

// ─────────────────────────── Identity ────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  // bcrypt hash. Never store plaintext.
  passwordHash String
  role         Role     @default(CLIENT)
  // Brute-force protection: lock the account for a cooldown after repeated
  // failed logins (see src/auth.ts). Reset to 0 on a successful sign-in.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     ProjectMembership[]
  uploadedPhotos  Photo[]             @relation("PhotoUploader")
  uploadedDocs    DesignDocument[]    @relation("DocUploader")
  authoredEvents  CalendarEvent[]     @relation("EventAuthor")
  submittedClaims ProgressClaim[]     @relation("ClaimSubmitter")
  eventResponses  CalendarEventResponse[]
}

// Join between User and Project. This is the row-level scoping anchor:
// a CLIENT can only reach a project they have a membership for.
model ProjectMembership {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  // Role on THIS project (a builder is implicitly on all; clients are scoped here).
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

// ─────────────────────────── Project ─────────────────────────

model Project {
  id            String   @id @default(cuid())
  name          String
  // Free-text site address; high-end residential = one home per project.
  address       String?
  clientName    String?
  // Headline contract value in cents (excludes approved variations).
  contractValueCents Int  @default(0)
  status        String   @default("ACTIVE") // ACTIVE | ON_HOLD | COMPLETE
  // Lifecycle phase — drives which module suite is primary.
  phase         ProjectPhase @default(BUILD)
  // What the client currently sees (builder-controlled). See ProjectClientView.
  clientView    ProjectClientView @default(CONSTRUCTION)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships     ProjectMembership[]
  costCodes       CostCode[]
  estimateImports EstimateImport[]
  estimateLines   EstimateLineItem[]
  costActuals     CostActual[]
  progressClaims  ProgressClaim[]
  variations      Variation[]
  scheduleItems   ScheduleItem[]
  scheduleImports ScheduleImport[]
  calendarEvents  CalendarEvent[]
  photos          Photo[]
  photoFolders    PhotoFolder[]
  designDocuments DesignDocument[]
  xeroConnection  XeroConnection?
  // Handover + Maintenance
  handoverDocuments HandoverDocument[]
  warranties        Warranty[]
  maintenanceItems  MaintenanceScheduleItem[]
  serviceBookings   ServiceBooking[]
  quoteRequests     QuoteRequest[]
  // RFIs + fortnightly updates
  rfis              Rfi[]
  updates           ProjectUpdate[]
  // Client-facing "who to contact at J Group" list
  contacts          ProjectContact[]
  // Subcontractor directory (shown in Handover), Excel/CSV uploadable
  subcontractors    SubcontractorContact[]

  @@index([status])
}

// ─────────────────────────── Cost codes ──────────────────────
// The shared key that ties Estimate ↔ Xero actuals ↔ Cost-to-Complete ↔ claims.

model CostCode {
  id          String  @id @default(cuid())
  projectId   String
  code        String // e.g. "1.10", "CARP", "ELEC-01"
  name        String
  createdAt   DateTime @default(now())

  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  estimateLines EstimateLineItem[]
  costActuals   CostActual[]
  claimLines    ClaimLineItem[]

  @@unique([projectId, code])
  @@index([projectId])
}

// ─────────────────────────── Estimate ────────────────────────

// Keep the source Excel file + parse metadata for audit.
model EstimateImport {
  id           String   @id @default(cuid())
  projectId    String
  // Storage key from src/lib/storage (NOT a public URL).
  sourceKey    String
  originalName String
  rowCount     Int      @default(0)
  importedById String?
  createdAt    DateTime @default(now())

  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   EstimateLineItem[]

  @@index([projectId])
}

model EstimateLineItem {
  id            String  @id @default(cuid())
  projectId     String
  importId      String?
  costCodeId    String?
  description   String
  quantity      Float   @default(1) // quantities CAN be fractional (m³, hrs); money cannot.
  unit          String? // "m2", "ea", "hrs", "item"
  unitCostCents Int     @default(0)
  totalCents    Int     @default(0) // stored, validated against qty * unitCost on import
  sortOrder     Int     @default(0)

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  import   EstimateImport? @relation(fields: [importId], references: [id], onDelete: SetNull)
  costCode CostCode?       @relation(fields: [costCodeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([costCodeId])
}

// ─────────────── Cost actuals (Xero sync target) ─────────────
// One-directional: Xero → dashboard. Populated by src/lib/xero/sync.ts (TODO).

model CostActual {
  id            String   @id @default(cuid())
  projectId     String
  costCodeId    String?
  // Xero source identifiers for idempotent upserts.
  xeroAccountCode String?
  xeroSourceId    String? // invoice/bill/transaction id
  description   String?
  amountCents   Int      @default(0)
  occurredAt    DateTime
  syncedAt      DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCode CostCode? @relation(fields: [costCodeId], references: [id], onDelete: SetNull)

  @@unique([projectId, xeroSourceId])
  @@index([projectId])
  @@index([costCodeId])
}

// ─────────────────────────── Progress claims ─────────────────

model ProgressClaim {
  id             String      @id @default(cuid())
  projectId      String
  claimNumber    Int
  status         ClaimStatus @default(DRAFT)
  periodStart    DateTime?
  periodEnd      DateTime?
  // Reconciliation sheet (uploaded or generated PDF/xlsx) storage key.
  reconSheetKey  String?
  // Original source filename of the uploaded reconciliation sheet.
  reconSheetName String?
  // Builder's "what happened in the last two weeks" note, shown to the client.
  narrative      String?

  // ── Recon-derived summary (set when a reconciliation sheet is parsed) ──
  periodLabel     String? // e.g. "Apr-26"
  reconInvoiceRef String? // e.g. "Xero Inv 736"
  labourCents     Int     @default(0) // labour this period
  costsCents      Int     @default(0) // supplier/subcontractor costs this period
  marginPercent   Float   @default(12.5) // builder's margin %
  marginCents     Int     @default(0)
  subtotalCents   Int     @default(0) // labour + costs + margin (ex-GST)
  gstCents        Int     @default(0)
  totalCents      Int     @default(0) // inc GST — the headline claim amount

  submittedById  String?
  submittedAt    DateTime?
  approvedAt     DateTime?
  // Set when pushed to Xero. Push itself is a flagged TODO (never auto-fires).
  xeroInvoiceId  String?
  // Uploaded Xero-generated tax invoice (PDF) with J Group payment details —
  // the document the client pays from.
  xeroInvoiceKey  String?
  xeroInvoiceName String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedBy  User?              @relation("ClaimSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  lines        ClaimLineItem[]
  reconLines   ClaimReconLine[]
  invoiceFiles ClaimInvoiceFile[]

  @@unique([projectId, claimNumber])
  @@index([projectId])
}

// Uploaded supplier-invoice files backing a claim — shown to the client for
// transparency. Distinct from xeroInvoiceKey (the tax invoice the client pays).
model ClaimInvoiceFile {
  id           String   @id @default(cuid())
  claimId      String
  fileKey      String
  originalName String
  createdAt    DateTime @default(now())

  claim ProgressClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model ClaimLineItem {
  id                  String  @id @default(cuid())
  claimId             String
  costCodeId          String?
  description         String
  // Percent complete this claim asserts for the cost code (0–100).
  percentComplete     Float   @default(0)
  // Value claimed THIS period, in cents (the recon "Current" column).
  claimedAmountCents  Int     @default(0)
  // Budget Overview context from the recon sheet.
  priorCents          Int     @default(0)
  toDateCents         Int     @default(0)

  claim    ProgressClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  costCode CostCode?     @relation(fields: [costCodeId], references: [id], onDelete: SetNull)

  @@index([claimId])
}

// Supplier-invoice backup behind a claim (the recon sheet's top section).
model ClaimReconLine {
  id             String  @id @default(cuid())
  claimId        String
  supplier       String
  documentNumber String?
  allocation     String? // budget allocation / cost code name
  amountCents    Int     @default(0) // ex-GST

  claim ProgressClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

// ─────────────────────────── Variations ──────────────────────

model Variation {
  id             String          @id @default(cuid())
  projectId      String
  variationNumber Int
  title          String
  description    String?
  status         VariationStatus @default(DRAFT)
  // Cached sum of line items, in cents. Recomputed on line write.
  totalCents     Int             @default(0)
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  project Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   VariationLineItem[]
  quotes  SubcontractorQuote[]

  @@unique([projectId, variationNumber])
  @@index([projectId])
}

model VariationLineItem {
  id            String @id @default(cuid())
  variationId   String
  description   String
  quantity      Float  @default(1)
  unit          String?
  unitCostCents Int    @default(0)
  totalCents    Int    @default(0)

  variation Variation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@index([variationId])
}

model SubcontractorQuote {
  id           String   @id @default(cuid())
  variationId  String
  vendorName   String
  amountCents  Int      @default(0)
  // Uploaded quote file (PDF/image) storage key.
  fileKey      String
  originalName String
  createdAt    DateTime @default(now())

  variation Variation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@index([variationId])
}

// ─────────────────────────── Schedule ────────────────────────
// Same Excel-import pattern as the estimate; updated fortnightly.

model ScheduleImport {
  id           String   @id @default(cuid())
  projectId    String
  sourceKey    String
  originalName String
  rowCount     Int      @default(0)
  importedById String?
  createdAt    DateTime @default(now())

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   ScheduleItem[]

  @@index([projectId])
}

model ScheduleItem {
  id          String    @id @default(cuid())
  projectId   String
  importId    String?
  // Trade / phase grouping (e.g. "Framing", "Electrical") for the Gantt view.
  group       String?
  taskName    String
  startDate   DateTime?
  endDate     DateTime?
  durationDays Int      @default(0)
  percentComplete Float @default(0)
  sortOrder   Int       @default(0)

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  import  ScheduleImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// ─────────────────────────── Calendar ────────────────────────
// Site meetings — visible + editable by both builder and client for the project.

model CalendarEvent {
  id          String   @id @default(cuid())
  projectId   String
  kind        CalendarEventKind @default(SITE_MEETING)
  title       String
  location    String?
  notes       String?
  startsAt    DateTime
  endsAt      DateTime
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("EventAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  responses CalendarEventResponse[]

  @@index([projectId])
}

// RSVP to a calendar event (site meeting). Clients/architects accept or decline;
// builders see who's coming. One response per user per event.
model CalendarEventResponse {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("ACCEPTED") // ACCEPTED | DECLINED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

// ─────────────────────────── Photos ──────────────────────────

model Photo {
  id           String   @id @default(cuid())
  projectId    String
  // Optional album/folder for grouping photos for the client.
  folderId     String?
  fileKey      String
  originalName String
  caption      String?
  // Fortnightly batches — taggable for filtering.
  takenAt      DateTime?
  uploadedById String?
  createdAt    DateTime @default(now())

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder     PhotoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy User?        @relation("PhotoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([folderId])
}

// Named album for grouping a project's photos (e.g. "Level 3 framing", "Kitchen").
model PhotoFolder {
  id        String   @id @default(cuid())
  projectId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photos  Photo[]

  @@index([projectId])
}

// ─────────────────── Architectural / interior docs ───────────

model DesignDocument {
  id           String        @id @default(cuid())
  projectId    String
  kind         DesignDocKind @default(ARCHITECTURAL)
  title        String
  fileKey      String
  originalName String
  uploadedById String?
  createdAt    DateTime      @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("DocUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// ─────────────────── Xero OAuth2 token store ─────────────────
// One connection per project (or tenant). Tokens written by the OAuth flow (TODO).

model XeroConnection {
  id            String   @id @default(cuid())
  projectId     String   @unique
  xeroTenantId  String?
  accessToken   String? // encrypt at rest in prod (TODO)
  refreshToken  String?
  expiresAt     DateTime?
  connectedAt   DateTime @default(now())
  lastSyncedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ════════════════════ HANDOVER PHASE ════════════════════════

// Reusable per-project document store (Register, O&M manuals, J Group docs,
// and warranty files). Structured warranty records live in Warranty.
model HandoverDocument {
  id           String          @id @default(cuid())
  projectId    String
  kind         HandoverDocKind
  title        String
  fileKey      String
  originalName String
  uploadedById String? // loose user ref
  createdAt    DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, kind])
}

// Warranty register — structured fields, optional certificate file.
model Warranty {
  id           String    @id @default(cuid())
  projectId    String
  item         String // what is covered (e.g. "Roof membrane")
  issuer       String // who issued it (e.g. manufacturer / trade)
  expiryDate   DateTime?
  notes        String?
  fileKey      String?
  originalName String?
  createdAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ════════════════════ MAINTENANCE PHASE ═════════════════════

model MaintenanceScheduleItem {
  id              String    @id @default(cuid())
  projectId       String
  title           String
  description     String?
  frequency       String? // free text e.g. "Every 6 months"
  nextDueDate     DateTime?
  calendarEventId String? // linked CalendarEvent(MAINTENANCE) when a due date is set
  createdAt       DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Client requests/books a service; builder schedules + manages. When scheduled,
// a typed CalendarEvent(BOOKING) is created so it appears on the shared calendar.
model ServiceBooking {
  id              String               @id @default(cuid())
  projectId       String
  requestedById   String? // loose user ref (client)
  title           String
  description     String?
  status          ServiceBookingStatus @default(REQUESTED)
  scheduledAt     DateTime?
  calendarEventId String? // linked CalendarEvent when scheduled
  createdAt       DateTime             @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Client raises a quote request off a maintenance/service need; builder responds.
model QuoteRequest {
  id              String             @id @default(cuid())
  projectId       String
  requestedById   String? // loose user ref (client)
  title           String
  description     String?
  status          QuoteRequestStatus @default(OPEN)
  quoteAmountCents Int? // builder's quoted price (cents)
  response        String? // builder's written response
  createdAt       DateTime           @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ════════════════════ RFIs (design questions) ═══════════════
// Builder raises a design question to the client; the client answers.
model Rfi {
  id           String    @id @default(cuid())
  projectId    String
  number       Int
  subject      String
  question     String
  status       RfiStatus @default(OPEN)
  answer       String?
  dueDate      DateTime?
  raisedById   String? // builder (loose ref)
  answeredById String? // client (loose ref)
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
}

// ════════════════════ Fortnightly summary ═══════════════════
// Dated site-update entries with a written summary + attached photos.
model ProjectUpdate {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  body        String
  createdById String?
  createdAt   DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photos  UpdatePhoto[]

  @@index([projectId])
}

model UpdatePhoto {
  id           String   @id @default(cuid())
  updateId     String
  fileKey      String
  originalName String
  createdAt    DateTime @default(now())

  update ProjectUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)

  @@index([updateId])
}

// ════════════════════ J Group contacts ══════════════════════
// Client-facing list of who to contact at J Group for this project (PM, site
// supervisor, accounts…). Curated by the builder; visible to client + architect
// in every view (it's never hidden by the client-view switch).
model ProjectContact {
  id        String   @id @default(cuid())
  projectId String
  name      String
  role      String? // e.g. "Project Manager", "Site Supervisor", "Accounts"
  phone     String?
  email     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Subcontractor directory for a project — the trades who worked on the build,
// shown in Handover so the owner can reach them for warranty/maintenance.
// Curated by the builder via Excel/CSV upload or manual entry; client read-only.
model SubcontractorContact {
  id          String   @id @default(cuid())
  projectId   String
  trade       String? // e.g. "Electrical", "Plumbing", "Tiling"
  company     String?
  contactName String?
  phone       String?
  email       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
